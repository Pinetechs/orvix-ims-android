<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OrvixIMS" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/orvix_primary</item>
        <item name="colorPrimaryVariant">@color/orvix_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orvix_accent</item>
        <item name="android:windowBackground">@color/orvix_background</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:statusBarColor">@color/orvix_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="OrvixButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btn_main_selector</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/btn_text_selector</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="OrvixButton.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/orvix_primary</item>
        <item name="strokeColor">@color/orvix_border</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="OrvixInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/input_stroke_selector</item>
        <item name="hintTextColor">@color/orvix_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="startIconTint">@color/orvix_primary</item>
        <item name="endIconTint">@color/orvix_text_sub</item>
    </style>

    <style name="OrvixCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/orvix_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>
</resources>
