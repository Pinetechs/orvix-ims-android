<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/OrvixCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/requestNumberTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/orvix_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="RCHK-23-001" />

            <TextView
                android:id="@+id/statusChipTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_warning"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="@color/warning"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Pending" />
        </LinearLayout>

        <TextView
            android:id="@+id/taskNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/orvix_text_main"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="Vehicle Inventory July" />

        <TextView
            android:id="@+id/taskReferenceTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/orvix_text_sub"
            android:textSize="12sp"
            tools:text="Task INV-2026-023" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/domainChipTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_blue"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="@color/orvix_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Vehicle" />

            <TextView
                android:id="@+id/imageRequiredTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_warning"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="@string/recheck_image_required_short"
                android:textColor="@color/warning"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/workAreaTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_location_24"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            android:textColor="@color/orvix_text_main"
            android:textSize="14sp"
            tools:text="Marka Branch" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/orvix_border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dueAtTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/orvix_text_sub"
                android:textSize="12sp"
                tools:text="Due: 24 Jul 2026, 10:00" />

            <TextView
                android:id="@+id/itemProgressTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/orvix_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="2 / 5 items" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
