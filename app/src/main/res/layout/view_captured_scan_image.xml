<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/capturedImageCard"
    style="@style/OrvixCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:visibility="gone"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Captured barcode image"
            android:textColor="@color/orvix_text_main"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/capturedBarcodeImageView"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:adjustViewBounds="true"
            android:background="@drawable/bg_result_panel"
            android:contentDescription="Captured barcode image"
            android:padding="8dp"
            android:scaleType="fitCenter" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
