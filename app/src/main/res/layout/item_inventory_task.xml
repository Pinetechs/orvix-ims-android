<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/taskNumberTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TASK-0001"
            android:textColor="@color/orvix_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/companyTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Company"
            android:textColor="@color/orvix_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/domainStatusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="VEHICLE • READY_TO_START"
            android:textColor="@color/orvix_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/countersTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Planned: 0 | Scanned: 0 | Mismatch: 0"
            android:textColor="@color/orvix_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
