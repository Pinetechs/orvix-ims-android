<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".OrvixApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Orvix IMS"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OrvixIMS"
        android:usesCleartextTraffic="${usesCleartextTraffic}">

        <activity
            android:name=".bootstrap.presentation.UpdateRequiredActivity"
            android:exported="false" />

        <activity
            android:name=".bootstrap.presentation.SetupActivity"
            android:exported="false" />

        <activity
            android:name=".scan.presentation.vehicle.VehicleScanActivity"
            android:exported="false" />

        <activity
            android:name=".scan.presentation.sparepart.SparePartScanActivity"
            android:exported="false" />

        <activity
            android:name=".scan.presentation.asset.AssetScanActivity"
            android:exported="false" />

        <activity
            android:name=".workarea.presentation.HierarchyListActivity"
            android:exported="false" />

        <activity
            android:name=".workarea.presentation.WorkAreaActivity"
            android:exported="false" />

        <activity
            android:name=".core.hardware.presentation.ScannerSettingsActivity"
            android:label="Scanner Settings"
            android:exported="false" />

        <activity
            android:name=".core.hardware.presentation.SymbologyListActivity"
            android:label="Select Barcodes"
            android:exported="false" />

        <activity
            android:name=".task.presentation.TaskListActivity"
            android:exported="false" />

        <activity
            android:name=".auth.presentation.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.OrvixIMS">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
